rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {
    // 로그인한 사용자만 자신의
    // 할 일 읽기/쓰기 가능
    match /todos/{userId}/{doc=**} {
      allow read, write:
        if request.auth != null
        && request.auth.uid == userId;
    }
    // 교사만 전체 목록 조회
    match /todos/{doc=**} {
      allow read:
        if request.auth.token.role == 'teacher';
    }
  }
}
